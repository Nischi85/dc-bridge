bridge:
  host: 0.0.0.0
  port: 8000
  log_level: INFO

airdcpp:
  url: http://CHANGE.ME:54921
  username: CHANGE_ME
  password: CHANGE_ME
  hub_urls: []              # empty = search all connected hubs

sonarr:
  url: http://CHANGE.ME:8989
  api_key: "CHANGE_ME"      # Sonarr Settings -> General -> API Key

radarr:
  url: http://CHANGE.ME:7878
  api_key: "CHANGE_ME"      # Radarr Settings -> General -> API Key

# When configured, the bridge filters its worklist to only items that have an
# active Jellyseerr request in one of `active_statuses`. Items not in Jellyseerr
# at all (or in declined/available/unavailable) are skipped by the poller.
# Leave api_key empty to disable the filter and revert to polling everything.
jellyseerr:
  url: http://CHANGE.ME:5055
  api_key: "CHANGE_ME"      # Jellyseerr Settings -> General -> API Key
  active_statuses: [pending, approved, processing]
  force_available_on_stuck: true    # force request -> available when *arr won't import the bridge's grab
  force_available_grace_hours: 6.0  # wait this long after the grab lands before giving up on *arr

# How the AirDC++ client sees the source layer. Its Z:\ drive (an SMB share) maps
# to `linux_root` on the host, so the host path /mnt/user/media/verified/X corresponds
# to Z:\verified\X. Set both to match your own AirDC++ download share.
path_map:
  linux_root: /mnt/user/media
  windows_root: "Z:"

# Translate paths from *arr webhook payloads (series.path / movie.folderPath) into
# host filesystem paths. The first matching arr_prefix wins. This lets you use any
# number of root folders in Sonarr/Radarr (TV, Movies, Documentaries, ...) without
# per-root config — they all match the same rule because they share one prefix.
#
# Path chain: *arr sees /share/<X>  (its container view of the media library)
#         -> host /mnt/user/media/verified/<X>  (the source layer, where AirDC++ writes)
#         -> AirDC++ SMB Z:\verified\<X>  (path_map applies, separators flipped)
path_translate:
  - arr_prefix: /share
    fs_prefix: /mnt/user/media/verified

# Match + dedup behavior. Once an episode/movie key is queued, the bridge never
# queues another release for the same key, regardless of later/better matches.
quality:
  # PRIMARY: name a Sonarr/Radarr QUALITY PROFILE (same name in both apps) and the
  # bridge uses its allowed qualities, most-preferred first (source+resolution, e.g.
  # WEB 720p before WEB 1080p before BluRay 1080p). Manage which qualities in the
  # *arr UI; swap which profile here. Empty -> use each item's own assigned profile.
  profile_name: "DC Single"
  # FALLBACK, used only if the named profile can't be read (e.g. *arr API down).
  # `priority` is an explicit ordered list of "<source> <resolution>" specs (source
  # matches a substring: WEB/HDTV/BluRay/DVD); accepted_keywords + resolutions are
  # the older keyword/resolution pair used when `priority` is empty too.
  priority: []
  accepted_keywords: [WEB, WEB-DL, BluRay, HDTV, WEBRip]
  resolutions: [1080p, 720p]  # accepted resolutions, in preference order
  # These bounds are checked against the *total release size* (sum of all files
  # in the hub release folder), not per-file. Multi-volume RAR releases of one
  # TV episode are typically 1.5–4 GB total. Always applied, on top of the profile.
  episode_size_mb: [200, 12000]
  movie_size_mb: [1000, 30000]

poller:
  interval_seconds: 900       # 15 min per full sweep
  per_item_jitter_seconds: 60 # spread requests
  # Delay (hours) after a TV episode's air date before the bridge starts
  # searching for it — scene releases usually appear a while after broadcast.
  # 0 = search from air time; 24 = wait 1 day; supports fractions (e.g. 6).
  air_offset_hours: 0
  # A movie is only "done" once its queued release folder actually appears on
  # disk (verified via AirDC++). If it never lands / stays a partial for longer
  # than this many hours, the bridge assumes the grab stalled and re-searches it.
  download_grace_hours: 24
  # TV: an episode that aired within this window is searched at the fresh cadence
  # below, capping (never slowing) the age back-off. New requests still search
  # every sweep.
  fresh_episode_hours: 48
  fresh_episode_every_seconds: 7200  # every 2h
  # Content-age back-off. Older CONTENT is searched less often, where age is
  # measured from when the title became available — a movie's release date, or a
  # series' newest still-wanted aired episode — NOT when it was requested. So a
  # freshly-requested 3-year-old movie backs off immediately, while a brand-new
  # release keeps searching every sweep. The poller picks the LAST tier whose
  # `older_than_days` matches; content younger than every tier searches every
  # sweep. An empty list disables back-off. Order tiers small -> large age.
  backoff:
    - older_than_days: 1         # 1–7 d old: once per day
      search_every_seconds: 86400
    - older_than_days: 7         # 7–30 d old: every 2 days
      search_every_seconds: 172800
    - older_than_days: 30        # 30–90 d old: every 4 days
      search_every_seconds: 345600
    - older_than_days: 90        # 90+ d old: once per week
      search_every_seconds: 604800

# Background re-sync from Jellyseerr/sonarr/radarr so newly-requested items pick
# up an active request_status without you having to POST /sync manually. Set to
# 0 to disable. The first sync runs ~10s after the container starts.
auto_sync:
  interval_seconds: 900

# Route children's content to dedicated *arr root folders by genre. A movie/series
# carrying any listed genre is relocated (metadata move, moveFiles=false — files are
# never touched) to the matching root, so its download and *arr management land
# there. Items that already have a file are left in place. Empty roots/genres
# disable the feature. The roots must already exist in Radarr/Sonarr.
children_routing:
  genres: [Family]
  movies_root: /share/Kids/Movies
  series_root: /share/Kids/Series

# File logging on top of stdout (docker logs). The file is reset on each container
# start and rotates by size (keeps one .1 backup) once it hits max_size_mb. The
# path is INSIDE the container; the default lives in the /config mount so it
# persists without an extra bind-mount. Empty log_file = stdout only (docker logs).
logging:
  log_file: /config/dc-bridge.log
  max_size_mb: 50

# Auto-approve PENDING Jellyseerr requests so they flow into Sonarr/Radarr and
# download without manual approval. Movies are always approved; a TV request is
# approved only when its requested seasons total <= tv_max_episodes (season 0
# specials excluded) so a huge series isn't grabbed automatically. Disabled by
# default. Turn OFF Jellyseerr's own auto-approve for this gate to apply to TV.
auto_approve:
  enabled: false
  tv_max_episodes: 10

# Release denylists. Both are matched whole-token and case-insensitive, only within
# the scene-tag block after the year/SxxExx marker — so a language word in the title
# (e.g. The.Danish.Girl, Russian.Doll) is never falsely rejected. A tag you DON'T
# list is kept; the defaults below deliberately omit Nordic (SWEDISH/NORWEGiAN/
# FiNNiSH), East-Asian (KOREAN/JAPANESE/CHINESE) and MULTi. An empty list disables
# that filter. Omit the whole block to keep these defaults.
filters:
  # Reject foreign-DUB releases tagged with any of these (full words + scene
  # abbreviations). DANSK is a standalone Danish tag, so it lives here.
  reject_dub_tags: [GERMAN, FRENCH, ITALIAN, SPANISH, POLISH, RUSSIAN, CZECH,
                    HUNGARIAN, PORTUGUESE, BRAZILIAN, TURKISH, DUTCH, UKRAINIAN,
                    ROMANIAN, BULGARIAN, HINDI, DANSK,
                    PL, PLDUB, PLSUB, GER, ITA, SPA, FRE, RUS, CZ, HUN, RO, UA, HEB]
  # Reject English-audio releases muxed with subs in these languages. Each stem
  # matches "<stem>sub"/"<stem>subs" with an optional dot, e.g. DK -> DKsubs / DK.SUBS.
  reject_sub_tags: [DK, DANiSH]
  # Reject adult/porn releases (whole-token). A request whose own title carries one
  # of these tags is exempt, so an adult title still matches its own releases.
  reject_adult_tags: [XXX]

# Match preferences. The other matching guards (movie title-at-start, anchored TV
# title, movie-vs-TV reject) are NOT configurable on purpose — they prevent
# wrong-grabs; see the "What the bridge filters" section in the README.
match:
  grab_specials: false   # true = also grab Season 0 (S00) specials/OVAs
  year_tolerance: 1      # a movie's year must be within ±this of the request (0 = exact)
